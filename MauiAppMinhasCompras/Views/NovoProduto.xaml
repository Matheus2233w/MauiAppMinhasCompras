<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppMinhasCompras.Views.NovoProduto"
             Title="NovoProduto">

    <ContentPage.ToolbarItems>

        <ToolbarItem Text="Salvar" Clicked="ToolbarItem_Clicked"/>

    </ContentPage.ToolbarItems>
    
    
    
    
    <VerticalStackLayout Padding="10" Spacing="10">
        
        <Label Text="Descrição do produto:" />
        <Entry x:Name="txt_descricao" />

        <Label Text="Quantidade:" />
        <Entry x:Name="txt_quantidade" Keyboard="Numeric" />

        <Label Text="Preço Unitário:" />
        <Entry x:Name="txt_preco" Keyboard="Numeric" />

        <HorizontalStackLayout Spacing="10" Padding="10" HorizontalOptions="Center">
    <Picker x:Name="pck_categoria" Title="Filtrar Categoria" WidthRequest="200"
            SelectedIndexChanged="pck_filtro_SelectedIndexChanged">
        <Picker.ItemsSource>
            <x:Array Type="{x:Type x:String}">
                <x:String>Todos</x:String>
                <x:String>Alimentos</x:String>
                <x:String>Higiene</x:String>
                <x:String>Limpeza</x:String>
            </x:Array>
        </Picker.ItemsSource>
    </Picker>

    <Button Text="Ver Soma" Clicked="btn_Somar_Clicked" BackgroundColor="Green" />
</HorizontalStackLayout>

    </VerticalStackLayout>
</ContentPage>